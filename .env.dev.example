# =============================================================================
# Development environment template — copy to `.env.dev` and adjust as needed.
# Used by `docker-compose.yml` (development).
# =============================================================================

# ----- Django -----
# Generate one with: python -c "import secrets;print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=dev-only-not-secret-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,web

# CSRF trusted origins (scheme + host, comma separated)
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ----- CORS — comma-separated list of allowed frontend origins -----
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ----- Database (PostgreSQL service inside the compose network) -----
POSTGRES_DB=shava_db
POSTGRES_USER=shava_user
POSTGRES_PASSWORD=shava_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ----- DRF throttling -----
THROTTLE_AUTH=5/min
THROTTLE_REGISTER=10/hour
THROTTLE_HELPFUL=30/min

# ----- Logging -----
LOG_LEVEL=DEBUG

# ----- Frontend (Vite) — base URL of the backend API -----
VITE_API_BASE_URL=http://localhost:8000
