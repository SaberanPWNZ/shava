# =============================================================================
# Development environment template — copy to `.env.dev` and adjust as needed.
# Used by `docker-compose.yml` (development).
# =============================================================================

# ----- Django -----
# Generate one with: python -c "import secrets;print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=dev-only-not-secret-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,web

# CSRF trusted origins (scheme + host, comma separated)
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ----- CORS — comma-separated list of allowed frontend origins -----
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ----- Database (PostgreSQL service inside the compose network) -----
POSTGRES_DB=shava_db
POSTGRES_USER=shava_user
POSTGRES_PASSWORD=shava_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ----- DRF throttling -----
THROTTLE_AUTH=5/min
THROTTLE_REGISTER=10/hour
THROTTLE_HELPFUL=30/min
THROTTLE_EMAIL_VERIFY=5/hour
THROTTLE_PASSWORD_RESET=5/hour

# ----- Email (verification + password reset) -----
# Default backend is the console (logs emails to stdout) — perfect for local
# dev. Switch to `django.core.mail.backends.smtp.EmailBackend` to actually
# send mail.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@shava.local
# Public URL of the SvelteKit frontend; embedded in verification / reset
# links inside outbound emails.
FRONTEND_URL=http://localhost:5173

# ----- Logging -----
LOG_LEVEL=DEBUG

# ----- Redis (cache + Celery broker) -----
# Used by django-redis for `CACHES["default"]` and as the default
# Celery broker / result backend. Empty value falls back to in-process
# LocMemCache + ALWAYS_EAGER mode (single-process dev).
REDIS_URL=redis://redis:6379/0
# Override these only if you want to split the broker from cache.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
# Set to True to run tasks synchronously even when a broker is up
# (useful for one-off debugging).
CELERY_TASK_ALWAYS_EAGER=False

# ----- Sentry (observability) -----
# Leave empty in dev to disable. When set, both backend and frontend report
# unhandled exceptions; PII is off by default.
SENTRY_DSN=
# Same DSN exposed to the SvelteKit client/server bundles. Sentry DSNs are
# designed to be public — exposing them is intentional.
PUBLIC_SENTRY_DSN=
PUBLIC_SENTRY_ENVIRONMENT=development
# Released artefact identifier; CI sets this to ${{ github.sha }}.
PUBLIC_GIT_SHA=

# ----- Frontend (Vite) — base URL of the backend API (must include /api) -----
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ----- Object storage (django-storages + MinIO) -----
# Flip USE_S3_STORAGE=True to route every uploaded image through the
# MinIO container declared in docker-compose.yml. When False (default),
# uploads land on the local filesystem under MEDIA_ROOT, exactly like
# before — useful for keeping tests / single-node dev simple.
USE_S3_STORAGE=False
# Bucket auto-created by the `minio_init` container on first boot.
AWS_STORAGE_BUCKET_NAME=shava-media
# MinIO endpoint inside the compose network. For real S3 leave empty.
AWS_S3_ENDPOINT_URL=http://minio:9000
# Public URL used in API responses (must be reachable from the browser).
# In dev MinIO is bound to 127.0.0.1:9000; behind a CDN set this to the
# CDN origin so easy-thumbnails srcset URLs round-trip correctly.
AWS_S3_PUBLIC_URL=http://localhost:9000/shava-media
# MinIO root credentials — also used by the init container to create
# the bucket. In production set IAM-scoped access keys instead.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
AWS_S3_ACCESS_KEY_ID=minioadmin
AWS_S3_SECRET_ACCESS_KEY=minioadmin
AWS_S3_REGION_NAME=us-east-1
# MinIO and most S3-compatible services need path-style addressing.
AWS_S3_ADDRESSING_STYLE=path
# Local MinIO does not terminate TLS; flip to True for production S3.
AWS_S3_USE_SSL=False
