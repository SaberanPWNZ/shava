# =============================================================================
# Production environment template — copy to `.env.prod` and fill in REAL secrets.
# Used by `docker-compose.prod.yml`. Never commit the populated `.env.prod`.
# =============================================================================

# ----- Django -----
# REQUIRED. Django will refuse to start without this when DEBUG=False
# (raises ImproperlyConfigured at import time).
# Generate with: python -c "import secrets;print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=__CHANGE_ME__GENERATE_A_LONG_RANDOM_STRING__
# MUST be False in production.
DEBUG=False
# Hostnames that the Django backend will accept. Include your real domain.
ALLOWED_HOSTS=example.com,www.example.com

# CSRF trusted origins MUST include scheme (https://) for production.
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Public domain used by nginx server_name (no scheme).
DOMAIN_NAME=example.com

# ----- TLS/HTTPS hardening (set when serving over HTTPS via nginx) -----
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ----- CORS — comma-separated list of allowed frontend origins -----
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# ----- Database (PostgreSQL service inside the compose network) -----
POSTGRES_DB=shava_db
POSTGRES_USER=shava_user
# REQUIRED. Use a long random password — never commit a real value.
POSTGRES_PASSWORD=__CHANGE_ME__STRONG_DB_PASSWORD__
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ----- DRF throttling -----
THROTTLE_AUTH=5/min
THROTTLE_REGISTER=10/hour
THROTTLE_HELPFUL=30/min
THROTTLE_EMAIL_VERIFY=5/hour
THROTTLE_PASSWORD_RESET=5/hour

# ----- Email (verification + password reset) -----
# Default backend stays "console" so a fresh VPS install boots without SMTP.
# Switch to `django.core.mail.backends.smtp.EmailBackend` and fill in the
# `EMAIL_HOST*` values once an SMTP relay is wired (Mailgun, SES, etc.).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=__CHANGE_ME__SMTP_USER__
EMAIL_HOST_PASSWORD=__CHANGE_ME__SMTP_PASSWORD__
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com
# Public URL of the frontend (single-domain deploy: same host as the API).
# Embedded in verification / reset links inside outbound emails.
FRONTEND_URL=https://example.com

# ----- django-axes — brute-force protection on login -----
# Lockout per (username, ip_address). Disable only for debugging.
AXES_ENABLED=True
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME_HOURS=1
# Number of trusted reverse proxies in front of Django (nginx = 1).
AXES_PROXY_COUNT=1

# ----- Logging -----
LOG_LEVEL=INFO

# ----- Redis (cache + Celery broker) -----
# Required in prod: enables django-redis for CACHES["default"] and is
# the broker for Celery worker/beat. Use a unique DB (`/0`) per stack.
REDIS_URL=redis://redis:6379/0
# Override only when the broker / result backend live elsewhere.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=False

# ----- Gunicorn -----
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60

# ----- Frontend (SvelteKit / Vite) — public base URL of the backend API
# Must include the /api path because the frontend appends endpoints like
# `/token/refresh/` directly to this value.
VITE_API_BASE_URL=https://example.com/api/v1

# ----- Sentry (observability) -----
# Backend DSN — used by sentry-sdk[django]. Same value can also be put in
# PUBLIC_SENTRY_DSN below if you want a single shared project for client +
# server, or split into two projects for clearer signal-to-noise.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# Release tag — usually the git SHA injected by CI.
GIT_SHA=
# Performance / profiling sample rates (0.0 disables). Keep low at first.
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
# Public DSN read by the SvelteKit bundles. Sentry DSNs are public by
# design, but you can use a separate "frontend" project here.
PUBLIC_SENTRY_DSN=
PUBLIC_SENTRY_ENVIRONMENT=production
PUBLIC_GIT_SHA=
PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.0

# ----- Object storage (django-storages + S3) -----
# Production deployments should put user uploads on real S3 (or any
# S3-compatible service: MinIO, Cloudflare R2, DO Spaces, Backblaze B2)
# rather than local disk so multiple gunicorn replicas share state.
# Set USE_S3_STORAGE=True and fill the credentials below; leave empty
# to keep filesystem uploads (single-node deploys behind nginx).
USE_S3_STORAGE=False
AWS_STORAGE_BUCKET_NAME=
# Empty for AWS S3; set to e.g. https://s3.example.com for MinIO/R2.
AWS_S3_ENDPOINT_URL=
# Optional CDN/public URL — overrides MEDIA_URL when set.
AWS_S3_PUBLIC_URL=
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ADDRESSING_STYLE=path
AWS_S3_USE_SSL=True
# Optional: a custom CloudFront / R2 domain serving the bucket.
AWS_S3_CUSTOM_DOMAIN=
# Optional canned ACL (e.g. public-read); leave empty when the bucket
# policy already grants public-read or when you front it with a CDN.
AWS_S3_DEFAULT_ACL=
