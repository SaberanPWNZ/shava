{
	"name": "shava-frontend",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:e2e": "playwright test",
		"test:unit": "svelte-kit sync && vitest run",
		"test:unit:watch": "svelte-kit sync && vitest",
		"test": "npm run test:unit && npm run test:e2e",
		"generate:api": "openapi-typescript ${OPENAPI_SCHEMA_URL:-http://localhost:8000/api/schema/} --output src/lib/api/types.gen.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.18.0",
		"@playwright/test": "^1.49.1",
		"@rollup/rollup-linux-x64-gnu": "4.6.1",
		"@sentry/sveltekit": "^9.47.1",
		"@sveltejs/adapter-node": "^5.2.12",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@tailwindcss/forms": "^0.5.9",
		"@tailwindcss/typography": "^0.5.15",
		"@tailwindcss/vite": "^4.1.11",
		"@types/leaflet": "^1.9.12",
		"@vitest/coverage-v8": "^4.1.5",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^16.0.0",
		"happy-dom": "^20.9.0",
		"lightningcss": "^1.21.0",
		"openapi-typescript": "^7.13.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.1.11",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.20.0",
		"vite": "^7.0.4",
		"vitest": "^4.1.5",
		"zod": "^3.23.8"
	},
	"dependencies": {
		"leaflet": "^1.9.4"
	}
}
